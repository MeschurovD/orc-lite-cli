{
  "name": "orc-lite-cli",
  "version": "0.1.0",
  "description": "Lightweight orchestrator for autonomous task execution with built-in scheduler",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "orc-lite": "./dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepare": "([ -f dist/index.js ] || npx --yes -p typescript tsc) && chmod +x dist/index.js",
    "postinstall": "node scripts/ensure-global-bin.mjs",
    "build": "tsc && chmod +x dist/index.js",
    "build:watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "ai",
    "opencode",
    "automation",
    "orchestrator",
    "scheduler"
  ],
  "author": "MeschurovD",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "simple-git": "^3.27.0",
    "undici": "^8.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.3"
  }
}
